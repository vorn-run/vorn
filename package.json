{
  "name": "vorn",
  "version": "0.2.0",
  "packageManager": "yarn@4.13.0",
  "author": "Javier Canizalez <javier-canizalez@outlook.com>",
  "description": "AI Agent Terminal Manager - Stage Manager for coding agents",
  "main": "./out/main/index.js",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "electron-vite dev",
    "build:server": "cd packages/server && npx tsup src/index.ts --format cjs --target node22 --external node-pty --external libsql --clean",
    "build:web": "cd packages/web && npx vite build",
    "build": "yarn build:server && yarn build:web && electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "ci:local": "bash scripts/ci-local.sh",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "bash scripts/sync-versions.sh && yarn lint-staged",
    "pre-push": "yarn typecheck"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --max-warnings 0",
      "prettier --write"
    ],
    "*.{json,css,md,html}": "prettier --write"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tiptap/core": "^3.22.5",
    "@tiptap/extension-code-block": "^3.22.5",
    "@tiptap/extension-code-block-lowlight": "^3.22.5",
    "@tiptap/extension-link": "^3.22.5",
    "@tiptap/extension-list": "^3.22.5",
    "@tiptap/extension-placeholder": "^3.22.5",
    "@tiptap/extension-task-item": "^3.22.5",
    "@tiptap/extension-task-list": "^3.22.5",
    "@tiptap/extensions": "^3.22.5",
    "@tiptap/pm": "^3.22.5",
    "@tiptap/react": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "@tiptap/suggestion": "^3.22.5",
    "@xterm/addon-canvas": "^0.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^5.5.0",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "framer-motion": "^12.38.0",
    "libsql": "^0.5.29",
    "lowlight": "^3.3.0",
    "lucide-react": "1.8.0",
    "node-cron": "^4.2.1",
    "node-pty": "1.2.0-beta.12",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-grid-layout": "^2.2.3",
    "shiki": "^4.0.2",
    "ws": "^8.20.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "4.1.4",
    "@vitest/eslint-plugin": "^1.6.16",
    "electron": "^41.2.0",
    "electron-builder": "^26.9.0",
    "electron-vite": "^5.0.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^29.1.0",
    "lint-staged": "^16.4.0",
    "node-gyp": "^12.3.0",
    "postcss": "^8.5.10",
    "prettier": "^3.8.2",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^7.3.2",
    "vitest": "4.1.4"
  },
  "resolutions": {
    "serialize-javascript": "^7.0.5",
    "@xmldom/xmldom": "^0.8.10",
    "hono": "^4.12.14",
    "@hono/node-server": "^1.19.13",
    "lodash": "^4.18.1",
    "flatted": "^3.4.2",
    "tar": "^7.5.13",
    "path-to-regexp": "^8.4.2",
    "picomatch": "^4.0.4",
    "fastify": "^5.8.5"
  }
}
